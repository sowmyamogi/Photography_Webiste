---
// Get the data passed to this component
const { image, title, category } = Astro.props;
---

<div class="card">
  <img src={image} alt={title} />
  <div class="overlay">
    <h3>{title}</h3>
    <span>{category}</span>
  </div>
</div>

<style>
  .card {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
  }
  .card:hover {
    transform: translateY(-5px);
  }
  img {
    width: 100%;
    height: 300px;
    object-fit: cover; /* Ensures image fills box without stretching */
    display: block;
  }
  .overlay {
    position: absolute;
    bottom: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
    width: 100%;
    padding: 20px;
    color: white;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .card:hover .overlay {
    opacity: 1;
  }
  h3 { margin: 0; font-size: 1.2rem; }
  span { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #ccc; }

  


</style>